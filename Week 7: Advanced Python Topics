# 9. Pipeline with generators
print("\n9. PIPELINE WITH GENERATORS:")
print("-"*40)

def read_numbers():
    """Generate numbers from 1 to 10"""
    for i in range(1, 11):
        yield i

def filter_even(numbers):
    """Filter even numbers"""
    for num in numbers:
        if num % 2 == 0:
            yield num

def square(numbers):
    """Square each number"""
    for num in numbers:
        yield num ** 2

def add_one(numbers):
    """Add one to each number"""
    for num in numbers:
        yield num + 1

# Create pipeline
pipeline = add_one(square(filter_even(read_numbers())))

print("Pipeline result (even numbers -> square -> add 1):")
for result in pipeline:
    print(f"  {result}", end=" ")
print()

# 10. Practical: Data streaming with generators
print("\n10. DATA STREAMING WITH GENERATORS:")

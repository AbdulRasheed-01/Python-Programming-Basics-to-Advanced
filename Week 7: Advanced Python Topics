import os

@contextlib.contextmanager
def change_directory(path):
    """Temporarily change working directory"""
    original = os.getcwd()
    print(f"  Original directory: {original}")
    os.chdir(path)
    print(f"  Changed to: {os.getcwd()}")
    try:
        yield
    finally:
        os.chdir(original)
        print(f"  Restored to: {os.getcwd()}")

# Create a test directory
os.makedirs("test_dir", exist_ok=True)

with change_directory("test_dir"):
    print("    Inside test_dir")
    with open("test.txt", "w") as f:
        f.write("Hello")

print(f"  Back in original directory")

# 10. Context manager for resource pooling
print("\n10. RESOURCE POOLING:")
print("-"*40)

class ConnectionPool:
    """Simple connection pool"""
    
    def __init__(self, size=3):
        self.size = size
        self.available = list(range(size))
        self.in_use = []
    
    @contextlib.contextmanager
    def get_connection(self):
        """Get a connection from the pool"""
        if not self.available:
            raise Exception("No available connections")
        
        conn = self.available.pop()
        self.in_use.append(conn)
        print(f"  Acquired connection {conn}")
        
        try:
            yield conn
        finally:
            self.in_use.remove(conn)
            self.available.append(conn)
            print(f"  Released connection {conn}")

pool = ConnectionPool(2)

# Use connections
with pool.get_connection() as conn1:
    print(f"    Using connection {conn1}")
    with pool.get_connection() as conn2:
        print(f"    Using connection {conn2}")


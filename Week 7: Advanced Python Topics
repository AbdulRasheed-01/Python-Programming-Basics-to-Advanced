# 12. Deadlock example
print("\n12. DEADLOCK PREVENTION:")
print("-"*40)

lock1 = threading.Lock()
lock2 = threading.Lock()

def worker1():
    with lock1:
        print("  Worker1 acquired lock1")
        time.sleep(0.1)
        with lock2:
            print("  Worker1 acquired lock2")

def worker2():
    with lock1:  # Same order as worker1 prevents deadlock
        print("  Worker2 acquired lock1")
        time.sleep(0.1)
        with lock2:
            print("  Worker2 acquired lock2")

t1 = threading.Thread(target=worker1)
t2 = threading.Thread(target=worker2)
t1.start()
t2.start()
t1.join()
t2.join()
print("  No deadlock occurred (correct lock ordering)")


import random

def sensor_data_stream():
    """Simulate continuous sensor data"""
    while True:
        yield {
            'timestamp': time.time(),
            'temperature': random.uniform(20, 30),
            'humidity': random.uniform(40, 60),
            'pressure': random.uniform(1000, 1020)
        }
        time.sleep(0.5)

def moving_average(data_stream, window_size=5):
    """Calculate moving average of data stream"""
    window = []
    for data in data_stream:
        window.append(data['temperature'])
        if len(window) > window_size:
            window.pop(0)
        avg_temp = sum(window) / len(window)
        yield {**data, 'avg_temperature': avg_temp}

# Process stream for a few samples
print("Processing sensor data stream (5 samples):")
stream = sensor_data_stream()
processed = moving_average(stream)

for i, data in enumerate(processed):
    if i >= 5:
        break
    print(f"  Sample {i+1}: Temp={data['temperature']:.2f}°C, "
          f"Avg={data['avg_temperature']:.2f}°C, "
          f"Humidity={data['humidity']:.1f}%")

# Clean up
import os
if os.path.exists("sample.txt"):
    os.remove("sample.txt")
    print("\n✅ Cleaned up sample.txt")

                links = [l for l in links if l.startswith('http')][:50]
                
                page_data = PageData(
                    url=url,
                    title=title,
                    headings=headings,
                    links=links,
                    text_length=len(html),
                    status_code=response.status,
                    content_type=response.headers.get('content-type', ''),
                    timestamp=time.time()
                )
                
                # Cache the result
                self._save_to_cache(url, page_data.to_dict())
                
                return page_data
                
        except Exception as e:
            self.logger.error(f"Error fetching {url}: {e}")
            return PageData(
                url=url,
                title="",
                headings=[],
                links=[],
                text_length=0,
                status_code=0,
                content_type="",
                timestamp=time.time(),
                error=str(e)
            )
    
    async def scrape_urls(self, urls, progress_callback=None):
        """Scrape multiple URLs concurrently"""
        async with ScraperSession("Advanced Scraper") as session:
            # Create semaphore for rate limiting
            semaphore = asyncio.Semaphore(self.max_concurrent)
            
            async def fetch_with_semaphore(url):
                async with semaphore:
                    result = await self.fetch_page(session, url)
                    if progress_callback:
                        progress_callback(url, result)
                    return result
            
            # Create tasks
            tasks = [fetch_with_semaphore(url) for url in urls]
            
            # Gather results
            results = await asyncio.gather(*tasks, return_exceptions=True)
            
            # Process results
            for result in results:
                if isinstance(result, PageData):
                    self.results.append(result)
                    session.stats.total_urls += 1
                    if result.error:
                        session.stats.failed += 1
                    else:
                        session.stats.successful += 1
                        session.stats.total_size += result.text_length
            
            return self.results
    
    def scrape_sync(self, urls):
        """Synchronous wrapper for scrape_urls"""
        return asyncio.run(self.scrape_urls(urls))
    
    @timer
    def scrape_with_threads(self, urls, num_threads=5):
        """Scrape using thread pool (for I/O bound)"""
        results = []
        
        def scrape_single(url):
            try:
                import requests
                response = requests.get(url, timeout=10)
                results.append({
                    'url': url,
                    'status': response.status_code,
                    'size': len(response.content)
                })
            except Exception as e:
                results.append({
                    'url': url,
                    'error': str(e)
                })
        
        with ThreadPoolExecutor(max_workers=num_threads) as executor:
            list(executor.map(scrape_single, urls))
        
        return results
    
    @timer
    def scrape_with_processes(self, urls, num_processes=4):
        """Scrape using process pool (for CPU-bound parsing)"""
        
        def parse_single(url):
            try:
                import requests
                from bs4 import BeautifulSoup
                
                response = requests.get(url, timeout=10)
                soup = BeautifulSoup(response.text, 'html.parser')
                
                return {
                    'url': url,
                    'title': soup.title.string if soup.title else '',
                    'links': len(soup.find_all('a')),
                    'size': len(response.text)
                }
            except Exception as e:
                return {'url': url, 'error': str(e)}
        
        with ProcessPoolExecutor(max_workers=num_processes) as executor:
            results = list(executor.map(parse_single, urls))
        
        return results
    
    def save_results(self, format='json', filename=None):
        """Save results to file"""
        if not filename:
            filename = f"scrape_results_{int(time.time())}.{format}"
        
        data = [r.to_dict() for r in self.results]
        
        if format == 'json':
            with open(filename, 'w') as f:
                json.dump(data, f, indent=2)
        
        elif format == 'csv':
            with open(filename, 'w', newline='') as f:
                if data:
                    writer = csv.DictWriter(f, fieldnames=data[0].keys())
                    writer.writeheader()
                    writer.writerows(data)
        
        elif format == 'txt':
            with open(filename, 'w') as f:
                for r in self.results:
                    f.write(f"\n{'='*60}\n")
                    f.write(f"URL: {r.url}\n")
                    f.write(f"Title: {r.title}\n")
                    f.write(f"Status: {r.status_code}\n")
                    f.write(f"Size: {r.text_length:,} bytes\n")
                    if r.headings:
                        f.write("Headings:\n")
                        for h in r.headings[:5]:
                            f.write(f"  • {h}\n")
        
        print(f"✅ Results saved to {filename}")
        return filename
    
    def analyze_results(self):
        """Analyze scraping results"""
        if not self.results:
            print("No results to analyze")
            return
        
        successful = [r for r in self.results if not r.error]
        failed = [r for r in self.results if r.error]
        
        print("\n" + "="*60)
        print("📊 ANALYSIS RESULTS")
        print("="*60)
        
        print(f"\n📈 Overview:")
        print(f"  Total URLs: {len(self.results)}")
        print(f"  Successful: {len(successful)} ({len(successful)/len(self.results)*100:.1f}%)")
        print(f"  Failed: {len(failed)}")
        
        if successful:
            print(f"\n📄 Content Stats:")
            sizes = [r.text_length for r in successful]
            print(f"  Total data: {sum(sizes):,} bytes")
            print(f"  Average size: {sum(sizes)/len(sizes):,.0f} bytes")
            print(f"  Min size: {min(sizes):,} bytes")
            print(f"  Max size: {max(sizes):,} bytes")
            
            print(f"\n🔗 Link Stats:")
            links_count = sum(len(r.links) for r in successful)
            print(f"  Total links found: {links_count:,}")
            print(f"  Average links per page: {links_count/len(successful):.1f}")
            
            print(f"\n🏷️  Title Stats:")
            titles = [r.title for r in successful if r.title]
            print(f"  Pages with titles: {len(titles)}/{len(successful)}")
            
            if failed:
                print(f"\n❌ Failed URLs:")
                for r in failed[:5]:
                    print(f"  • {r.url}: {r.error}")
                if len(failed) > 5:
                    print(f"  ... and {len(failed)-5} more")
        
        print("\n" + "="*60)


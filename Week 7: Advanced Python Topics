print("="*60)

import time
import threading
import multiprocessing
import asyncio
import concurrent.futures
import requests
from datetime import datetime

# 1. Threading basics
print("\n1. THREADING BASICS:")
print("-"*40)

def worker(name, delay):
    """Simple worker function"""
    print(f"  Thread {name} starting")
    time.sleep(delay)
    print(f"  Thread {name} finished after {delay}s")

# Create threads
threads = []
for i in range(3):
    t = threading.Thread(target=worker, args=(f"Thread-{i}", i+1))
    threads.append(t)
    t.start()

# Wait for all threads
for t in threads:
    t.join()
print("  All threads completed")

# 2. Thread pool
print("\n2. THREAD POOL:")
print("-"*40)

def task(n):
    print(f"  Task {n} starting")
    time.sleep(1)
    return f"Task {n} result"

with concurrent.futures.ThreadPoolExecutor(max_workers=3) as executor:
    futures = [executor.submit(task, i) for i in range(5)]
    
    for future in concurrent.futures.as_completed(futures):
        print(f"  Got: {future.result()}")

# 3. Race condition example
print("\n3. RACE CONDITION:")
print("-"*40)

counter = 0

def increment():
    global counter
    for _ in range(100000):
        counter += 1

# Without lock
threads = []
for _ in range(10):
    t = threading.Thread(target=increment)
    threads.append(t)
    t.start()

for t in threads:
    t.join()

print(f"  Counter without lock: {counter} (should be 1,000,000)")

# With lock
counter = 0
lock = threading.Lock()

def increment_with_lock():
    global counter
    for _ in range(100000):
        with lock:
            counter += 1

threads = []
for _ in range(10):
    t = threading.Thread(target=increment_with_lock)
    threads.append(t)
    t.start()

for t in threads:
    t.join()

print(f"  Counter with lock: {counter} (correct value)")

# 4. Producer-Consumer pattern
print("\n4. PRODUCER-CONSUMER PATTERN:")
print("-"*40)

import queue
import random

def producer(q, items):
    """Produce items"""
    for i in range(items):
        item = random.randint(1, 100)
        q.put(item)
        print(f"  Produced: {item}")
        time.sleep(random.random())
    q.put(None)  # Sentinel

def consumer(q, name):
    """Consume items"""
    while True:
        item = q.get()
        if item is None:
            q.put(None)  # Pass sentinel to other consumers
            break
        print(f"  {name} consumed: {item}")
        time.sleep(random.random() * 2)

q = queue.Queue(maxsize=5)
prod = threading.Thread(target=producer, args=(q, 10))
cons1 = threading.Thread(target=consumer, args=(q, "Consumer1"))
cons2 = threading.Thread(target=consumer, args=(q, "Consumer2"))

prod.start()
cons1.start()
cons2.start()

prod.join()
cons1.join()
cons2.join()

# 5. Multiprocessing basics
print("\n5. MULTIPROCESSING BASICS:")
print("-"*40)

def cpu_intensive(n):
    """CPU-intensive task"""
    result = 0
    for i in range(n):
        result += i ** 2
    return result

# Sequential
start = time.time()
results_seq = [cpu_intensive(10**7) for _ in range(4)]
seq_time = time.time() - start
print(f"  Sequential time: {seq_time:.2f}s")

# Parallel with multiprocessing
start = time.time()
with multiprocessing.Pool(processes=4) as pool:
    results_par = pool.map(cpu_intensive, [10**7] * 4)
par_time = time.time() - start
print(f"  Parallel time: {par_time:.2f}s")
print(f"  Speedup: {seq_time/par_time:.1f}x")

# 6. Shared memory between processes
print("\n6. SHARED MEMORY BETWEEN PROCESSES:")
print("-"*40)

def worker_process(name, counter, lock):
    """Process worker with shared counter"""
    for _ in range(100):
        with lock:
            counter.value += 1
    print(f"  Process {name} finished")

if __name__ == "__main__":
    # Using Value for shared memory
    counter = multiprocessing.Value('i', 0)
    lock = multiprocessing.Lock()
    
    processes = []
    for i in range(4):
        p = multiprocessing.Process(target=worker_process, 
                                   args=(f"P{i}", counter, lock))
        processes.append(p)
        p.start()
    
    for p in processes:
        p.join()
    
    print(f"  Final counter value: {counter.value}")

# 7. Asyncio basics
print("\n7. ASYNCIO BASICS:")
print("-"*40)

async def async_worker(name, delay):
    """Async worker"""
    print(f"  Async {name} starting")
    await asyncio.sleep(delay)
    print(f"  Async {name} finished after {delay}s")
    return f"Result from {name}"

async def main_async():
    # Run tasks concurrently
    tasks = [
        async_worker("A", 2),
        async_worker("B", 1),
        async_worker("C", 3)
    ]
    
    results = await asyncio.gather(*tasks)
    print(f"  Results: {results}")

# Run async code
asyncio.run(main_async())

# 8. Asyncio with aiohttp (web requests)
print("\n8. ASYNCIO WITH HTTP REQUESTS:")
print("-"*40)

import aiohttp

async def fetch_url(session, url):
    """Fetch URL asynchronously"""
    async with session.get(url) as response:
        return await response.text()

async def fetch_all():
    """Fetch multiple URLs concurrently"""
    urls = [
        'http://example.com',
        'http://httpbin.org/get',
        'http://httpbin.org/status/200'
    ]
    
    async with aiohttp.ClientSession() as session:
        tasks = [fetch_url(session, url) for url in urls]
        results = await asyncio.gather(*tasks, return_exceptions=True)
        
        for url, result in zip(urls, results):
            if isinstance(result, Exception):
                print(f"  Error fetching {url}: {result}")
            else:
                print(f"  Fetched {url}: {len(result)} bytes")

# Run async HTTP requests
asyncio.run(fetch_all())


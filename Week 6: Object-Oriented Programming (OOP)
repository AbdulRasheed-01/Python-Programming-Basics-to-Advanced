# 8. Property decorator chain
print("\n8. PROPERTY DECORATOR CHAIN:")
print("-"*40)

class User:
    def __init__(self, first_name, last_name):
        self._first_name = first_name
        self._last_name = last_name
    
    @property
    def first_name(self):
        return self._first_name
    
    @first_name.setter
    def first_name(self, value):
        if not value:
            raise ValueError("First name cannot be empty")
        self._first_name = value
        # Invalidate cached full name
        if hasattr(self, '_full_name'):
            del self._full_name
    
    @property
    def last_name(self):
        return self._last_name
    
    @last_name.setter
    def last_name(self, value):
        if not value:
            raise ValueError("Last name cannot be empty")
        self._last_name = value
        # Invalidate cached full name
        if hasattr(self, '_full_name'):
            del self._full_name
    
    @property
    def full_name(self):
        """Cached computed property"""
        if not hasattr(self, '_full_name'):
            print("  Computing full name...")
            self._full_name = f"{self._first_name} {self._last_name}"
        return self._full_name

user = User("John", "Doe")
print(f"First access: {user.full_name}")
print(f"Second access (cached): {user.full_name}")

# Change name - cache is invalidated
user.first_name = "Jane"
print(f"After name change: {user.full_name}")

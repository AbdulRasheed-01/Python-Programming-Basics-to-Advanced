class BankAccount:
    def __init__(self, owner, balance):
        self.owner = owner          # Public
        self._balance = balance      # "Protected" (convention)
        self.__pin = "1234"          # "Private" (name mangling)
    
    def get_balance(self):
        """Getter method"""
        return self._balance
    
    def deposit(self, amount):
        if amount > 0:
            self._balance += amount
    
    def __str__(self):
        return f"Account of {self.owner}: ${self._balance}"

account = BankAccount("Alice", 1000)
print(f"Public attribute: {account.owner}")
print(f"Protected attribute (accessible but convention says don't): {account._balance}")

# Name mangling - private attributes are renamed
print(f"Private attribute name mangling: {account._BankAccount__pin}")

try:
    print(account.__pin)  # This will fail
except AttributeError as e:
    print(f"❌ Cannot access __pin directly: {e}")

# 2. Properties with getters/setters
print("\n2. PROPERTIES WITH GETTERS/SETTERS:")
print("-"*40)

class Temperature:
    def __init__(self, celsius=0):
        self._celsius = celsius
    
    @property
    def celsius(self):
        """Getter for celsius"""
        print("  Getting celsius value")
        return self._celsius
    
    @celsius.setter
    def celsius(self, value):
        """Setter for celsius with validation"""
        print(f"  Setting celsius to {value}")
        if value < -273.15:
            raise ValueError("Temperature below absolute zero!")
        self._celsius = value
    
    @property
    def fahrenheit(self):
        """Computed property (read-only)"""
        return (self._celsius * 9/5) + 32
    
    @fahrenheit.setter
    def fahrenheit(self, value):
        """Setter for fahrenheit (converts to celsius)"""
        self.celsius = (value - 32) * 5/9
    
    @property
    def kelvin(self):
        """Computed property"""
        return self._celsius + 273.15

# Use properties
temp = Temperature(25)
print(f"Initial celsius: {temp.celsius}")
print(f"In fahrenheit: {temp.fahrenheit}")
print(f"In kelvin: {temp.kelvin}")

# Set using property setter

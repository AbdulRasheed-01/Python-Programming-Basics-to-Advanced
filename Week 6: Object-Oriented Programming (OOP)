# 4. Abstract base classes
print("\n4. ABSTRACT BASE CLASSES:")
print("-"*40)

from abc import ABC, abstractmethod

class Shape(ABC):
    """Abstract base class for shapes"""
    
    @abstractmethod
    def area(self):
        """Calculate area - must be implemented by subclass"""
        pass
    
    @abstractmethod
    def perimeter(self):
        """Calculate perimeter - must be implemented by subclass"""
        pass
    
    def describe(self):
        """Concrete method - can be used as is"""
        return f"Area: {self.area():.2f}, Perimeter: {self.perimeter():.2f}"

class Rectangle(Shape):
    def __init__(self, width, height):
        self.width = width
        self.height = height
    
    def area(self):
        return self.width * self.height
    
    def perimeter(self):
        return 2 * (self.width + self.height)

class Circle(Shape):
    def __init__(self, radius):
        self.radius = radius
    
    def area(self):
        import math
        return math.pi * self.radius ** 2
    
    def perimeter(self):
        import math
        return 2 * math.pi * self.radius

# Create shapes
rect = Rectangle(5, 3)
circle = Circle(4)

print(f"Rectangle:")
print(f"  Area: {rect.area():.2f}")
print(f"  Perimeter: {rect.perimeter():.2f}")
print(f"  {rect.describe()}")

print(f"\nCircle:")
print(f"  Area: {circle.area():.2f}")
print(f"  Perimeter: {circle.perimeter():.2f}")
print(f"  {circle.describe()}")

# Try to instantiate abstract class (will fail)
try:
    shape = Shape()
except TypeError as e:
    print(f"\n❌ Cannot instantiate abstract class: {e}")


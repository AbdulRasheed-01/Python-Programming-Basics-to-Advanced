class SecretVault:
    def __init__(self):
        self._secrets = []
    
    @property
    def secrets(self):
        """Getter for secrets"""
        return self._secrets.copy()  # Return a copy to prevent modification
    
    @secrets.setter
    def secrets(self, value):
        """Setter - not allowed"""
        raise AttributeError("Cannot set secrets directly. Use add_secret()")
    
    @secrets.deleter
    def secrets(self):
        """Delete all secrets"""
        print("  Deleting all secrets!")
        self._secrets.clear()
    
    def add_secret(self, secret):
        """Add a secret"""
        self._secrets.append(secret)
        print(f"  Secret added: {secret}")


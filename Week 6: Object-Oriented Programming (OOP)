# 3. Class with validation
print("\n3. CLASS WITH VALIDATION:")
print("-"*40)

class BankAccount:
    """Bank account with validation"""
    
    def __init__(self, owner, balance=0):
        self.owner = owner
        self._balance = 0  # Private attribute (by convention)
        self.deposit(balance)  # Use method for validation
        self.transactions = []
    
    def deposit(self, amount):
        """Deposit money with validation"""
        if amount <= 0:
            raise ValueError("Deposit amount must be positive")
        self._balance += amount
        self.transactions.append(f"Deposit: +${amount}")
        return self._balance
    
    def withdraw(self, amount):
        """Withdraw money with validation"""
        if amount <= 0:
            raise ValueError("Withdrawal amount must be positive")
        if amount > self._balance:
            raise ValueError("Insufficient funds")
        self._balance -= amount
        self.transactions.append(f"Withdrawal: -${amount}")
        return self._balance
    
    def get_balance(self):
        """Get current balance"""
        return self._balance
    
    def get_transaction_history(self):
        """Get all transactions"""
        return self.transactions
    
    def __str__(self):
        return f"Account of {self.owner}: ${self._balance}"

# Use the class
account = BankAccount("Alice", 1000)
print(f"Initial: {account}")

account.deposit(500)
print(f"After deposit: {account}")

account.withdraw(200)
print(f"After withdrawal: {account}")

print("\nTransaction history:")
for transaction in account.get_transaction_history():
    print(f"  {transaction}")

try:
    account.withdraw(2000)  # This should fail
except ValueError as e:
    print(f"\n❌ Error: {e}")

# 4. Class with properties
print("\n4. CLASS WITH PROPERTIES:")
print("-"*40)

class Circle:
    """Circle class with properties"""
    
    def __init__(self, radius):
        self._radius = radius
    
    @property
    def radius(self):
        """Getter for radius"""
        return self._radius
    
    @radius.setter
    def radius(self, value):
        """Setter for radius with validation"""
        if value <= 0:
            raise ValueError("Radius must be positive")
        self._radius = value
    
    @property
    def diameter(self):
        """Calculate diameter (read-only property)"""
        return self._radius * 2
    
    @property
    def area(self):
        """Calculate area (read-only property)"""
        import math
        return math.pi * self._radius ** 2
    
    @property
    def circumference(self):
        """Calculate circumference (read-only property)"""
        import math
        return 2 * math.pi * self._radius

# Use properties
circle = Circle(5)
print(f"Circle with radius: {circle.radius}")
print(f"Diameter: {circle.diameter}")
print(f"Area: {circle.area:.2f}")
print(f"Circumference: {circle.circumference:.2f}")

# Change radius using property setter
circle.radius = 10
print(f"\nAfter changing radius to 10:")
print(f"New area: {circle.area:.2f}")

try:
    circle.radius = -5  # This should fail
except ValueError as e:
    print(f"\n❌ Error: {e}")

# 5. Class methods and static methods
print("\n5. CLASS METHODS AND STATIC METHODS:")
print("-"*40)

class Employee:
    """Employee class with class and static methods"""
    
    # Class attributes
    company = "Tech Corp"
    raise_amount = 1.04
    
    def __init__(self, first, last, salary):
        self.first = first
        self.last = last
        self.salary = salary
        self.email = f"{first}.{last}@company.com"
    
    def fullname(self):
        """Instance method"""
        return f"{self.first} {self.last}"
    
    def apply_raise(self):
        """Apply raise to salary"""
        self.salary = int(self.salary * self.raise_amount)
    
    @classmethod
    def set_raise_amount(cls, amount):
        """Class method to change raise amount"""
        cls.raise_amount = amount
        print(f"Raise amount set to {amount}")
    
    @classmethod
    def from_string(cls, emp_string):
        """Alternative constructor using class method"""
        first, last, salary = emp_string.split('-')
        return cls(first, last, int(salary))
    
    @staticmethod
    def is_workday(day):
        """Static method - doesn't depend on class or instance"""
        # 0 = Monday, 6 = Sunday
        return day.weekday() < 5
    
    def __str__(self):
        return f"{self.fullname()} - ${self.salary}"

# Create employees
emp1 = Employee("John", "Doe", 50000)
emp2 = Employee("Jane", "Smith", 60000)

print(f"emp1: {emp1}")
print(f"emp2: {emp2}")

# Use class method
Employee.set_raise_amount(1.05)
emp1.apply_raise()
emp2.apply_raise()
print(f"\nAfter raise:")
print(f"emp1: {emp1}")
print(f"emp2: {emp2}")

# Use class method as alternative constructor

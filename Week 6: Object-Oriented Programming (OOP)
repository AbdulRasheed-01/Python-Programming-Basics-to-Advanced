# inheritance.py
"""
Inheritance in Python
"""

print("="*60)
print("INHERITANCE")
print("="*60)

# 1. Basic inheritance
print("\n1. BASIC INHERITANCE:")
print("-"*40)

class Animal:
    """Base class for all animals"""
    
    def __init__(self, name, age):
        self.name = name
        self.age = age
        print(f"  Animal __init__ called for {name}")
    
    def eat(self):
        return f"{self.name} is eating"
    
    def sleep(self):
        return f"{self.name} is sleeping"
    
    def make_sound(self):
        return f"{self.name} makes a sound"
    
    def __str__(self):
        return f"{self.name} (age {self.age})"

class Dog(Animal):
    """Dog class inherits from Animal"""
    
    def __init__(self, name, age, breed):
        # Call parent constructor
        super().__init__(name, age)
        self.breed = breed
        print(f"  Dog __init__ called for {name}")
    
    # Override parent method
    def make_sound(self):
        return f"{self.name} barks: Woof! Woof!"
    
    # Add new method
    def fetch(self):
        return f"{self.name} is fetching the ball"

class Cat(Animal):
    """Cat class inherits from Animal"""
    
    def __init__(self, name, age, color):
        super().__init__(name, age)
        self.color = color
    
    def make_sound(self):
        return f"{self.name} meows: Meow!"
    
    def scratch(self):
        return f"{self.name} is scratching"

# Create instances
dog = Dog("Buddy", 3, "Golden Retriever")
cat = Cat("Whiskers", 2, "Orange")

# Use inherited methods
print(f"\n{dog.eat()}")
print(dog.sleep())
print(dog.make_sound())
print(dog.fetch())

print(f"\n{cat.eat()}")
print(cat.sleep())
print(cat.make_sound())
print(cat.scratch())

# Check types
print(f"\nIs dog an Animal? {isinstance(dog, Animal)}")
print(f"Is dog a Dog? {isinstance(dog, Dog)}")
print(f"Is dog a Cat? {isinstance(dog, Cat)}")
print(f"Is Animal a parent of Dog? {issubclass(Dog, Animal)}")


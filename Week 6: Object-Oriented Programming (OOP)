class InstanceCounter:
    """Class that counts its instances"""
    
    instance_count = 0
    
    def __init__(self):
        InstanceCounter.instance_count += 1
        self.instance_number = InstanceCounter.instance_count
        print(f"  Instance #{self.instance_number} created")
    

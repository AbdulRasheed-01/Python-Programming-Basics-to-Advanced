class JSONMixin:
    """Mixin to add JSON serialization"""
    
    def to_json(self):
        import json
        return json.dumps(self.__dict__)

class XMLMixin:
    """Mixin to add XML serialization"""
    
    def to_xml(self):
        xml = f"<{self.__class__.__name__}>"
        for key, value in self.__dict__.items():
            xml += f"<{key}>{value}</{key}>"
        xml += f"</{self.__class__.__name__}>"
        return xml

class Person(JSONMixin, XMLMixin):
    def __init__(self, name, age, city):
        self.name = name
        self.age = age
        self.city = city


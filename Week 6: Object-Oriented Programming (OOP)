class Configuration:
    _instance = None
    _settings = {}
    
    @classmethod
    @property
    def instance(cls):
        """Singleton pattern with property"""
        if cls._instance is None:
            cls._instance = cls()
        return cls._instance
    
    @classmethod
    def get_setting(cls, key, default=None):
        return cls._settings.get(key, default)
    
    @classmethod
    def set_setting(cls, key, value):
        cls._settings[key] = value


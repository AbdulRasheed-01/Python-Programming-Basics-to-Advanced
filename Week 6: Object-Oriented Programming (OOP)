# 8. Composition vs Inheritance
print("\n8. COMPOSITION VS INHERITANCE:")
print("-"*40)

# Inheritance approach
class Engine:
    def start(self):
        return "Engine started"
    
    def stop(self):
        return "Engine stopped"

class CarWithInheritance(Engine):
    def __init__(self, make):
        self.make = make
    
    def drive(self):
        return f"{self.make} car is driving"

# Composition approach
class CarWithComposition:
    def __init__(self, make):
        self.make = make
        self.engine = Engine()  # Composition
    
    def start(self):
        return self.engine.start()
    
    def stop(self):
        return self.engine.stop()
    
    def drive(self):
        return f"{self.make} car is driving"

# Test both
car1 = CarWithInheritance("Toyota")
print("Inheritance:")
print(f"  {car1.start()}")
print(f"  {car1.drive()}")

car2 = CarWithComposition("Honda")
print("\nComposition:")
print(f"  {car2.start()}")
print(f"  {car2.drive()}")
print(f"  {car2.stop()}")

print("\nComposition is often preferred because:")
print("  - More flexible (can change engine at runtime)")
print("  - Better encapsulation")
print("  - Follows 'favor composition over inheritance' principle")



# 7. Extending built-in types
print("\n7. EXTENDING BUILT-IN TYPES:")
print("-"*40)

class IntList(list):
    """List that only accepts integers"""
    
    def append(self, item):
        if not isinstance(item, int):
            raise TypeError(f"Expected int, got {type(item).__name__}")
        super().append(item)
    
    @property
    def sum(self):
        return sum(self)
    
    @property
    def average(self):
        return sum(self) / len(self) if self else 0
    
    @property
    def product(self):
        result = 1
        for num in self:
            result *= num
        return result

# Use extended list

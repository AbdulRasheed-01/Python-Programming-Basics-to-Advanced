"""
Task management API endpoints
"""

from fastapi import APIRouter, Depends, HTTPException, status, Query
from sqlalchemy.ext.asyncio import AsyncSession
from typing import List, Optional
from datetime import datetime

from .. import schemas, crud, models
from ..database import get_db
from ..auth import get_current_active_user

router = APIRouter()

@router.post("/", response_model=schemas.TaskInDB, status_code=status.HTTP_201_CREATED)
async def create_task(
    task_data: schemas.TaskCreate,
    db: AsyncSession = Depends(get_db),
    current_user: models.User = Depends(get_current_active_user)
):
    """Create a new task"""
    task = await crud.create_task(db, task_data, current_user.id)
    return task

@router.get("/", response_model=List[schemas.TaskInDB])
async def get_tasks(
    skip: int = Query(0, ge=0),
    limit: int = Query(100, ge=1, le=1000),
    status: Optional[models.StatusEnum] = None,
    priority: Optional[models.PriorityEnum] = None,
    category_id: Optional[int] = None,
    tag_id: Optional[int] = None,
    search: Optional[str] = None,
    overdue_only: bool = False,
    sort_by: str = Query("created_at", regex="^(created_at|due_date|priority|title)$"),
    sort_desc: bool = True,
    db: AsyncSession = Depends(get_db),
    current_user: models.User = Depends(get_current_active_user)
):
    """Get user's tasks with filtering"""
    tasks = await crud.get_tasks(
        db, current_user.id, skip, limit, status, priority,
        category_id, tag_id, search, overdue_only, sort_by, sort_desc
    )
    return tasks

@router.get("/{task_id}", response_model=schemas.TaskInDB)
async def get_task(
    task_id: int,
    db: AsyncSession = Depends(get_db),
    current_user: models.User = Depends(get_current_active_user)
):
    """Get task by ID"""
    task = await crud.get_task(db, task_id, current_user.id)
    if not task:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="Task not found"
        )
    return task

@router.put("/{task_id}", response_model=schemas.TaskInDB)
async def update_task(
    task_id: int,
    task_data: schemas.TaskUpdate,
    db: AsyncSession = Depends(get_db),
    current_user: models.User = Depends(get_current_active_user)
):
    """Update task"""
    task = await crud.update_task(db, task_id, current_user.id, task_data)
    if not task:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="Task not found"
        )
    return task

@router.delete("/{task_id}", status_code=status.HTTP_204_NO_CONTENT)
async def delete_task(
    task_id: int,
    db: AsyncSession = Depends(get_db),
    current_user: models.User = Depends(get_current_active_user)
):
    """Delete task"""
    deleted = await crud.delete_task(db, task_id, current_user.id)
    if not deleted:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="Task not found"
        )

@router.post("/{task_id}/complete", response_model=schemas.TaskInDB)
async def complete_task(
    task_id: int,
    db: AsyncSession = Depends(get_db),
    current_user: models.User = Depends(get_current_active_user)
):
    """Mark task as completed"""
    task = await crud.get_task(db, task_id, current_user.id)
    if not task:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="Task not found"
        )
    
    update_data = schemas.TaskUpdate(status=models.StatusEnum.DONE)
    task = await crud.update_task(db, task_id, current_user.id, update_data)
    return task


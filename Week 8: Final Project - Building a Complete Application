"""

from fastapi import APIRouter, Request, Depends
from fastapi.responses import HTMLResponse
from fastapi.templating import Jinja2Templates
from sqlalchemy.ext.asyncio import AsyncSession
from .. import crud
from ..database import get_db
from ..auth import get_current_user
from ..models import User
from . import web_router

templates = Jinja2Templates(directory="app/templates")

@web_router.get("/", response_class=HTMLResponse)
async def home_page(request: Request):
    """Render home page"""
    return templates.TemplateResponse(
        "index.html",
        {"request": request}
    )

@web_router.get("/dashboard", response_class=HTMLResponse)
async def dashboard(
    request: Request,
    db: AsyncSession = Depends(get_db),
    current_user: User = Depends(get_current_user)
):
    """Render dashboard page"""
    if not current_user:
        return templates.TemplateResponse(
            "login.html",
            {"request": request, "error": "Please login to continue"}
        )
    
    # Get statistics
    stats = await crud.get_task_stats(db, current_user.id)
    
    # Get recent tasks
    recent_tasks = await crud.get_tasks(
        db, current_user.id, limit=5, sort_by="created_at", sort_desc=True
    )
    
    # Get upcoming tasks (due soon)
    upcoming_tasks = await crud.get_tasks(
        db, current_user.id, limit=5, sort_by="due_date", sort_desc=False
    )
    
    return templates.TemplateResponse(
        "dashboard.html",
        {
            "request": request,
            "user": current_user,
            "stats": stats,
            "recent_tasks": recent_tasks,
            "upcoming_tasks": upcoming_tasks
        }
    )


# celery_worker.py
"""
Celery worker for background tasks
"""

from celery import Celery
from celery.schedules import crontab
import asyncio
from app.config import settings
from app.database import AsyncSessionLocal
from app import crud, models
from datetime import datetime, timedelta
import logging
import smtplib
from email.mime.text import MIMEText
from email.mime.multipart import MIMEMultipart

logger = logging.getLogger(__name__)

# Create Celery app
celery_app = Celery(
    "taskflow",
    broker=settings.CELERY_BROKER_URL,
    backend=settings.CELERY_RESULT_BACKEND,
    include=["celery_worker"]
)

# Configure Celery
celery_app.conf.update(
    task_serializer="json",
    accept_content=["json"],
    result_serializer="json",
    timezone="UTC",
    enable_utc=True,
    task_track_started=True,
    task_time_limit=30 * 60,  # 30 minutes
    task_soft_time_limit=25 * 60,  # 25 minutes
)

# Schedule periodic tasks
celery_app.conf.beat_schedule = {
    "check-overdue-tasks": {
        "task": "celery_worker.check_overdue_tasks",
        "schedule": crontab(hour="*/1"),  # Every hour
    },
    "send-daily-digest": {
        "task": "celery_worker.send_daily_digest",
        "schedule": crontab(hour=8, minute=0),  # Every day at 8 AM
    },
    "cleanup-old-tasks": {
        "task": "celery_worker.cleanup_old_tasks",
        "schedule": crontab(day_of_week="sunday", hour=0, minute=0),  # Weekly
    },
}

@celery_app.task
def check_overdue_tasks():
    """Check for overdue tasks and send notifications"""
    logger.info("Checking for overdue tasks...")
    
    async def _run():
        async with AsyncSessionLocal() as db:
            # Get all overdue tasks
            tasks = await crud.get_overdue_tasks(db)
            
            for task in tasks:
                # Send notification (implement based on user preferences)
                logger.info(f"Task {task.id} is overdue: {task.title}")
                
                # You could send email here
                if task.owner.email:
                    send_overdue_notification.delay(task.id, task.owner.email)
    
    loop = asyncio.new_event_loop()
    asyncio.set_event_loop(loop)
    loop.run_until_complete(_run())
    loop.close()
    
    logger.info(f"Checked {len(tasks)} overdue tasks")

@celery_app.task
def send_overdue_notification(task_id: int, email: str):
    """Send overdue task notification email"""
    logger.info(f"Sending overdue notification for task {task_id} to {email}")
    
    # Email configuration
    if not settings.SMTP_HOST:
        logger.warning("SMTP not configured, skipping email")
        return
    
    msg = MIMEMultipart()
    msg["From"] = settings.EMAIL_FROM
    msg["To"] = email
    msg["Subject"] = "Task Overdue Notification"
    
    body = f"""
    <html>
        <body>
            <h2>Task Overdue</h2>
            <p>Your task (ID: {task_id}) is now overdue.</p>
            <p>Please log in to TaskFlow to review and update your tasks.</p>
            <br>
            <p><a href="http://localhost:8000/tasks/{task_id}">View Task</a></p>
        </body>
    </html>
    """
    
    msg.attach(MIMEText(body, "html"))
    
    try:
        with smtplib.SMTP(settings.SMTP_HOST, settings.SMTP_PORT) as server:
            if settings.SMTP_USER:
                server.starttls()
                server.login(settings.SMTP_USER, settings.SMTP_PASSWORD)
            server.send_message(msg)
        logger.info(f"Email sent successfully to {email}")
    except Exception as e:
        logger.error(f"Failed to send email: {e}")

@celery_app.task
def send_daily_digest():
    """Send daily task digest to users"""
    logger.info("Sending daily digests...")
    
    async def _run():
        async with AsyncSessionLocal() as db:
            # Get all active users
            users = await crud.get_users(db, active_only=True)
            
            for user in users:
                if not user.email:
                    continue
                
                # Get user's tasks for the day
                today_start = datetime.now().replace(hour=0, minute=0, second=0)
                today_end = today_start + timedelta(days=1)
                
                tasks = await crud.get_tasks(
                    db, user.id,
                    filters={
                        "due_date": {
                            "gte": today_start,
                            "lt": today_end
                        }
                    }
                )
                
                if tasks:
                    send_daily_digest_email.delay(user.id, user.email, [
                        {"id": t.id, "title": t.title} for t in tasks
                    ])
    
    loop = asyncio.new_event_loop()
    asyncio.set_event_loop(loop)
    loop.run_until_complete(_run())
    loop.close()


from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy import select, update, delete, and_, or_, func
from sqlalchemy.orm import selectinload, joinedload
from typing import Optional, List, Dict, Any
from datetime import datetime, timedelta
from . import models, schemas
from .auth import get_password_hash
import logging

logger = logging.getLogger(__name__)

# ===== User CRUD =====

async def get_user_by_id(db: AsyncSession, user_id: int) -> Optional[models.User]:
    """Get user by ID"""
    result = await db.execute(
        select(models.User).where(models.User.id == user_id)
    )
    return result.scalar_one_or_none()

async def get_user_by_email(db: AsyncSession, email: str) -> Optional[models.User]:
    """Get user by email"""
    result = await db.execute(
        select(models.User).where(models.User.email == email)
    )
    return result.scalar_one_or_none()

async def get_user_by_username(db: AsyncSession, username: str) -> Optional[models.User]:
    """Get user by username"""
    result = await db.execute(
        select(models.User).where(models.User.username == username)
    )
    return result.scalar_one_or_none()

async def create_user(db: AsyncSession, user_data: schemas.UserCreate) -> models.User:
    """Create a new user"""
    hashed_password = get_password_hash(user_data.password)
    
    db_user = models.User(
        email=user_data.email,
        username=user_data.username,
        full_name=user_data.full_name,
        hashed_password=hashed_password
    )
    
    db.add(db_user)
    await db.commit()
    await db.refresh(db_user)
    
    logger.info(f"Created user: {user_data.username}")
    return db_user

async def update_user(
    db: AsyncSession,
    user_id: int,
    user_data: schemas.UserUpdate
) -> Optional[models.User]:
    """Update user information"""
    user = await get_user_by_id(db, user_id)
    if not user:
        return None
    
    update_data = user_data.model_dump(exclude_unset=True)
    
    if 'password' in update_data:
        update_data['hashed_password'] = get_password_hash(update_data.pop('password'))
    
    for field, value in update_data.items():
        setattr(user, field, value)
    
    await db.commit()
    await db.refresh(user)
    
    logger.info(f"Updated user: {user.username}")
    return user

async def update_user_last_login(db: AsyncSession, user_id: int):
    """Update user's last login time"""
    await db.execute(
        update(models.User)
        .where(models.User.id == user_id)
        .values(last_login=datetime.now())
    )
    await db.commit()

async def delete_user(db: AsyncSession, user_id: int) -> bool:
    """Delete a user"""
    result = await db.execute(
        delete(models.User).where(models.User.id == user_id)
    )
    await db.commit()
    
    if result.rowcount > 0:
        logger.info(f"Deleted user {user_id}")
        return True
    return False

async def get_users(
    db: AsyncSession,
    skip: int = 0,
    limit: int = 100,
    active_only: bool = True
) -> List[models.User]:
    """Get list of users with pagination"""
    query = select(models.User)
    
    if active_only:
        query = query.where(models.User.is_active == True)
    
    query = query.offset(skip).limit(limit)
    result = await db.execute(query)
    
    return result.scalars().all()

# ===== Category CRUD =====

async def create_category(
    db: AsyncSession,
    category_data: schemas.CategoryCreate,
    user_id: int
) -> models.Category:
    """Create a new category"""
    db_category = models.Category(
        **category_data.model_dump(),
        user_id=user_id
    )
    
    db.add(db_category)
    await db.commit()
    await db.refresh(db_category)
    
    return db_category

async def get_categories(
    db: AsyncSession,
    user_id: int,
    skip: int = 0,
    limit: int = 100
) -> List[models.Category]:
    """Get user's categories"""
    result = await db.execute(
        select(models.Category)
        .where(models.Category.user_id == user_id)
        .offset(skip)
        .limit(limit)
        .options(selectinload(models.Category.tasks))
    )
    
    categories = result.scalars().all()
    
    # Add task count
    for cat in categories:
        cat.task_count = len([t for t in cat.tasks if t.status != models.StatusEnum.ARCHIVED])
    
    return categories

async def get_category(
    db: AsyncSession,
    category_id: int,
    user_id: int
) -> Optional[models.Category]:
    """Get category by ID"""
    result = await db.execute(
        select(models.Category)
        .where(
            and_(
                models.Category.id == category_id,
                models.Category.user_id == user_id
            )
        )
    )
    return result.scalar_one_or_none()

async def update_category(
    db: AsyncSession,
    category_id: int,
    user_id: int,
    category_data: schemas.CategoryUpdate
) -> Optional[models.Category]:
    """Update category"""
    category = await get_category(db, category_id, user_id)
    if not category:
        return None
    
    update_data = category_data.model_dump(exclude_unset=True)
    
    for field, value in update_data.items():
        setattr(category, field, value)
    
    await db.commit()
    await db.refresh(category)
    
    return category

async def delete_category(
    db: AsyncSession,
    category_id: int,
    user_id: int
) -> bool:
    """Delete category"""
    # First, set category_id to NULL for all tasks in this category
    await db.execute(
        update(models.Task)
        .where(
            and_(
                models.Task.category_id == category_id,
                models.Task.owner_id == user_id
            )
        )
        .values(category_id=None)
    )
    
    # Then delete the category
    result = await db.execute(
        delete(models.Category)
        .where(
            and_(
                models.Category.id == category_id,
                models.Category.user_id == user_id
            )
        )
    )
    
    await db.commit()
    return result.rowcount > 0

# ===== Task CRUD =====

async def create_task(
    db: AsyncSession,
    task_data: schemas.TaskCreate,
    user_id: int
) -> models.Task:
    """Create a new task"""
    tag_ids = task_data.tag_ids or []
    task_data_dict = task_data.model_dump(exclude={'tag_ids'})
    
    db_task = models.Task(
        **task_data_dict,
        owner_id=user_id
    )
    
    # Add tags if specified
    if tag_ids:
        result = await db.execute(
            select(models.Tag).where(models.Tag.id.in_(tag_ids))
        )
        tags = result.scalars().all()
        db_task.tags = tags
    
    db.add(db_task)
    await db.commit()
    await db.refresh(db_task)
    
    # Load relationships
    result = await db.execute(
        select(models.Task)
        .where(models.Task.id == db_task.id)
        .options(
            selectinload(models.Task.category),
            selectinload(models.Task.tags)
        )
    )
    db_task = result.scalar_one()
    
    logger.info(f"Created task {db_task.id} for user {user_id}")
    return db_task

async def get_tasks(
    db: AsyncSession,
    user_id: int,
    skip: int = 0,
    limit: int = 100,
    status: Optional[models.StatusEnum] = None,
    priority: Optional[models.PriorityEnum] = None,
    category_id: Optional[int] = None,
    tag_id: Optional[int] = None,
    search: Optional[str] = None,
    overdue_only: bool = False,
    sort_by: str = "created_at",
    sort_desc: bool = True
) -> List[models.Task]:
    """Get user's tasks with filtering and sorting"""
    
    query = select(models.Task).where(models.Task.owner_id == user_id)
    
    # Apply filters
    if status:
        query = query.where(models.Task.status == status)
    
    if priority:
        query = query.where(models.Task.priority == priority)
    
    if category_id:
        query = query.where(models.Task.category_id == category_id)
    
    if tag_id:
        query = query.join(models.Task.tags).where(models.Tag.id == tag_id)
    
    if overdue_only:
        query = query.where(
            and_(
                models.Task.due_date < datetime.now(),
                models.Task.status != models.StatusEnum.DONE,
                models.Task.status != models.StatusEnum.ARCHIVED
            )
        )
    
    if search:
        query = query.where(
            or_(
                models.Task.title.ilike(f"%{search}%"),
                models.Task.description.ilike(f"%{search}%")
            )
        )
    
    # Apply sorting
    if sort_desc:
        query = query.order_by(getattr(models.Task, sort_by).desc())
    else:
        query = query.order_by(getattr(models.Task, sort_by))
    
    # Apply pagination
    query = query.offset(skip).limit(limit)
    
    # Load relationships
    query = query.options(
        selectinload(models.Task.category),
        selectinload(models.Task.tags)
    )
    
    result = await db.execute(query)
    return result.scalars().all()

async def get_task(
    db: AsyncSession,
    task_id: int,
    user_id: int
) -> Optional[models.Task]:
    """Get task by ID"""
    result = await db.execute(
        select(models.Task)
        .where(
            and_(
                models.Task.id == task_id,
                models.Task.owner_id == user_id
            )
        )
        .options(
            selectinload(models.Task.category),
            selectinload(models.Task.tags)
        )
    )
    return result.scalar_one_or_none()

async def update_task(
    db: AsyncSession,
    task_id: int,
    user_id: int,
    task_data: schemas.TaskUpdate
) -> Optional[models.Task]:
    """Update task"""
    task = await get_task(db, task_id, user_id)
    if not task:
        return None
    
    update_data = task_data.model_dump(exclude_unset=True)
    tag_ids = update_data.pop('tag_ids', None)
    
    # Update task fields
    for field, value in update_data.items():
        setattr(task, field, value)
    
    # Update tags if specified
    if tag_ids is not None:
        result = await db.execute(
            select(models.Tag).where(models.Tag.id.in_(tag_ids))
        )
        task.tags = result.scalars().all()
    
    # If status changed to DONE, set completed_at
    if task_data.status == models.StatusEnum.DONE and not task.completed_at:
        task.completed_at = datetime.now()
    
    await db.commit()
    await db.refresh(task)
    
    # Reload with relationships
    result = await db.execute(
        select(models.Task)
        .where(models.Task.id == task_id)
        .options(
            selectinload(models.Task.category),
            selectinload(models.Task.tags)
        )
    )
    task = result.scalar_one()
    
    logger.info(f"Updated task {task_id} for user {user_id}")
    return task

async def delete_task(
    db: AsyncSession,
    task_id: int,
    user_id: int
) -> bool:
    """Delete task"""
    result = await db.execute(
        delete(models.Task)
        .where(
            and_(
                models.Task.id == task_id,
                models.Task.owner_id == user_id
            )
        )
    )
    await db.commit()
    
    if result.rowcount > 0:
        logger.info(f"Deleted task {task_id} for user {user_id}")
        return True
    return False

async def get_task_stats(db: AsyncSession, user_id: int) -> schemas.TaskStats:
    """Get task statistics for user"""
    
    # Get all tasks
    result = await db.execute(
        select(models.Task).where(models.Task.owner_id == user_id)
    )
    tasks = result.scalars().all()
    
    # Calculate stats
    total = len(tasks)
    todo = sum(1 for t in tasks if t.status == models.StatusEnum.TODO)
    in_progress = sum(1 for t in tasks if t.status == models.StatusEnum.IN_PROGRESS)
    review = sum(1 for t in tasks if t.status == models.StatusEnum.REVIEW)
    done = sum(1 for t in tasks if t.status == models.StatusEnum.DONE)
    archived = sum(1 for t in tasks if t.status == models.StatusEnum.ARCHIVED)
    overdue = sum(1 for t in tasks if t.is_overdue)
    
    # Priority breakdown
    urgent = sum(1 for t in tasks if t.priority == models.PriorityEnum.URGENT)
    high = sum(1 for t in tasks if t.priority == models.PriorityEnum.HIGH)
    medium = sum(1 for t in tasks if t.priority == models.PriorityEnum.MEDIUM)
    low = sum(1 for t in tasks if t.priority == models.PriorityEnum.LOW)
    
    completion_rate = (done / total * 100) if total > 0 else 0
    
    return schemas.TaskStats(
        total=total,
        todo=todo,
        in_progress=in_progress,
        review=review,
        done=done,
        archived=archived,
        overdue=overdue,
        completion_rate=completion_rate,
        urgent=urgent,
        high=high,
        medium=medium,
        low=low
    )

